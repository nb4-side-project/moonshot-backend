import { Router } from 'express';
{{#if includeAuth}}
import { authenticate } from '@/shared/middlewares/auth.js';
{{/if}}
import validate from '@/shared/middlewares/validate.js';
import asyncHandler from '@/shared/utils/async-handler.js';

import {{camelCase name}}Controller from './{{name}}.controller.js';
import { create{{pascalCase (singular name)}}Schema, update{{pascalCase (singular name)}}Schema, {{camelCase (singular name)}}IdParamsSchema } from './{{name}}.schema.js';

const router = Router();

{{#if includeAuth}}
// 모든 라우트에 인증 적용
router.use(authenticate);
{{/if}}

/** {{pascalCase (singular name)}} 생성 */
router.post('/', validate(create{{pascalCase (singular name)}}Schema, 'body'), asyncHandler({{camelCase name}}Controller.create));

/** {{pascalCase (singular name)}} 목록 조회 */
router.get('/', asyncHandler({{camelCase name}}Controller.getAll));

/** {{pascalCase (singular name)}} 상세 조회 */
router.get('/:id', validate({{camelCase (singular name)}}IdParamsSchema, 'params'), asyncHandler({{camelCase name}}Controller.getById));

/** {{pascalCase (singular name)}} 수정 */
router.patch(
    '/:id',
    validate({{camelCase (singular name)}}IdParamsSchema, 'params'),
    validate(update{{pascalCase (singular name)}}Schema, 'body'),
    asyncHandler({{camelCase name}}Controller.update),
);

/** {{pascalCase (singular name)}} 삭제 */
router.delete('/:id', validate({{camelCase (singular name)}}IdParamsSchema, 'params'), asyncHandler({{camelCase name}}Controller.delete));

export default router;
