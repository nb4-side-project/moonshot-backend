{
    "compilerOptions": {
        // =========================================
        // 📁 프로젝트 구조
        // =========================================
        "rootDir": "./src",
        "outDir": "./dist",

        // =========================================
        // ⚙️ 환경 설정 (Node 18~22 최적화)
        // =========================================
        "target": "ES2022",
        "module": "NodeNext",
        "moduleResolution": "NodeNext",
        "lib": ["ES2022"],
        "types": ["node"],

        // =========================================
        // 🧩 모듈 설정
        // =========================================
        "resolveJsonModule": true,
        "esModuleInterop": true,
        "forceConsistentCasingInFileNames": true,
        // "verbatimModuleSyntax": true, // 완전 ESM-only로 갈 때만 활성화 권장
        "isolatedModules": true,

        // =========================================
        // 🧾 출력 설정
        // =========================================
        "sourceMap": true,
        "declaration": true,
        "declarationMap": true,
        "removeComments": true,

        // =========================================
        // 🔒 타입 안정성
        // =========================================
        "strict": true,
        "noUncheckedIndexedAccess": true,
        "exactOptionalPropertyTypes": true,

        // =========================================
        // ✨ 코드 품질
        // =========================================
        "noUnusedLocals": true,
        "noUnusedParameters": true,
        "noImplicitReturns": true,
        "noFallthroughCasesInSwitch": true,

        // =========================================
        // ⚡ 성능 최적화
        // =========================================
        "skipLibCheck": true,
        "incremental": true,

        // =========================================
        // 🧬 데코레이터 (필요 시)
        // =========================================
        "experimentalDecorators": true,
        "emitDecoratorMetadata": true,
        "paths": {
            "@/*": ["./src/*"]
        }
    },
    "include": ["src/**/*.ts"],
    "exclude": ["node_modules", "dist"]
}
