# ===========================================
# 🌐 Server Configuration
# ===========================================
PORT=3001
NODE_ENV=development
BASE_URL=http://localhost:3001
CORS_ORIGINS=http://localhost:3000

# ===========================================
# 🗄️ Database (PostgreSQL)
# ===========================================
DATABASE_URL="postgresql://postgres:password@localhost:5432/dbname?schema=public"

# ===========================================
# 🔐 JWT Configuration
# ===========================================
# 아래 명령어로 랜덤 시크릿 생성
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ACCESS_TOKEN_SECRET="your-access-token-secret-here-32-chars-minimum"
REFRESH_TOKEN_SECRET="your-refresh-token-secret-here-32-chars-minimum"
ACCESS_TOKEN_EXPIRES_IN="15m"
REFRESH_TOKEN_EXPIRES_IN="7d"

# ===========================================
# ☁️ Cloudinary (이미지 업로드 - 선택)
# ===========================================
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# ===========================================
# 📁 File Uploads (Local Mode)
# ===========================================
UPLOAD_DIR="./uploads"

# ===========================================
# 📧 Email Configuration
# ===========================================
# 개발 환경(development): Nodemailer (SMTP) 사용
# 배포 환경(production): SendGrid API 사용

# Nodemailer (개발 환경용)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=dev@moonshot.com

# SendGrid (배포 환경용)
SENDGRID_API_KEY=your-sendgrid-api-key-here
SENDGRID_FROM=noreply@moonshot.com
