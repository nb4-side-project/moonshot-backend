{
    "name": "moonshot-backend",
    "version": "1.0.0",
    "description": "",
    "main": "dist/server.js",
    "engines": {
        "node": ">=18.0.0",
        "npm": ">=9.0.0"
    },
    "scripts": {
        "dev": "tsx watch --clear-screen=false src/server.ts",
        "dev:cloud": "NODE_ENV=production tsx watch --clear-screen=false src/server.ts",
        "build": "npm run clean && tsc",
        "start": "node dist/server.js",
        "start:prod": "npm run db:deploy && node dist/server.js",
        "clean": "rm -rf dist",
        "db:generate": "prisma generate",
        "db:migrate": "prisma migrate dev",
        "db:deploy": "prisma migrate deploy",
        "db:studio": "prisma studio",
        "db:validate": "prisma validate",
        "db:push": "prisma db push",
        "db:reset": "prisma migrate reset",
        "lint": "eslint 'src/**/*.ts' --fix",
        "lint:check": "eslint 'src/**/*.ts'",
        "format": "prettier --write 'src/**/*.ts' 'prisma/**/*.prisma'",
        "format:check": "prettier --check 'src/**/*.ts' 'prisma/**/*.prisma'",
        "type-check": "tsc --noEmit",
        "validate": "npm run type-check && npm run lint:check && npm run format:check",
        "test": "vitest",
        "test:watch": "vitest --watch",
        "test:coverage": "vitest --coverage",
        "test:ui": "vitest --ui",
        "prepare": "husky"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/nb4-side-project/moonshot-backend.git"
    },
    "keywords": [],
    "author": "",
    "license": "ISC",
    "type": "module",
    "bugs": {
        "url": "https://github.com/nb4-side-project/moonshot-backend/issues"
    },
    "homepage": "https://github.com/nb4-side-project/moonshot-backend#readme",
    "devDependencies": {
        "@commitlint/cli": "^20.1.0",
        "@commitlint/config-conventional": "^20.0.0",
        "@types/bcrypt": "^6.0.0",
        "@types/compression": "^1.8.1",
        "@types/cookie-parser": "^1.4.10",
        "@types/cors": "^2.8.19",
        "@types/express": "^5.0.5",
        "@types/jsonwebtoken": "^9.0.10",
        "@types/morgan": "^1.9.10",
        "@types/multer": "^2.0.0",
        "@types/node": "^24.9.2",
        "@typescript-eslint/eslint-plugin": "^8.59.3",
        "@typescript-eslint/parser": "^8.46.2",
        "@vitest/ui": "^4.0.5",
        "eslint": "^9.38.0",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-prettier": "^5.5.4",
        "husky": "^9.1.7",
        "lint-staged": "^16.2.6",
        "prettier": "^3.6.2",
        "prettier-plugin-prisma": "^5.0.0",
        "prisma": "^6.18.0",
        "tsx": "^4.20.6",
        "typescript": "^5.9.3",
        "typescript-eslint": "^8.46.2",
        "vitest": "^4.0.5"
    },
    "dependencies": {
        "@prisma/client": "^6.18.0",
        "@sendgrid/mail": "^8.1.6",
        "@types/nodemailer": "^7.0.3",
        "bcrypt": "^6.0.0",
        "cloudinary": "^2.8.0",
        "compression": "^1.8.1",
        "cookie-parser": "^1.4.7",
        "cors": "^2.8.5",
        "dotenv": "^17.2.3",
        "express": "^5.1.0",
        "express-rate-limit": "^8.2.0",
        "helmet": "^8.1.0",
        "jsonwebtoken": "^9.0.2",
        "morgan": "^1.10.1",
        "multer": "^2.0.2",
        "nodemailer": "^7.0.10",
        "zod": "^4.1.12"
    }
}
